<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true">
    <springProperty name="appName" source="spring.application.name" defaultValue="vaccination-backend"/>
    <springProperty name="logFile" source="logging.file.name" defaultValue="../logs/app.log"/>
    <springProperty name="maxFileSize" source="LOG_MAX_FILE_SIZE" defaultValue="10MB"/>
    <springProperty name="maxHistory" source="LOG_MAX_HISTORY" defaultValue="7"/>
    <springProperty name="totalSizeCap" source="LOG_TOTAL_SIZE_CAP" defaultValue="100MB"/>

    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"${appName}"}</customFields>
        </encoder>
    </appender>

    <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${logFile}</file>
        <append>true</append>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${logFile}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>${maxFileSize}</maxFileSize>
            <maxHistory>${maxHistory}</maxHistory>
            <totalSizeCap>${totalSizeCap}</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"${appName}"}</customFields>
        </encoder>
    </appender>

    <appender name="ASYNC_JSON_CONSOLE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>2048</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <neverBlock>true</neverBlock>
        <appender-ref ref="JSON_CONSOLE"/>
    </appender>

    <appender name="ASYNC_JSON_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>8192</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <neverBlock>true</neverBlock>
        <appender-ref ref="JSON_FILE"/>
    </appender>

    <root level="INFO">
        <appender-ref ref="ASYNC_JSON_CONSOLE"/>
        <appender-ref ref="ASYNC_JSON_FILE"/>
    </root>
</configuration>
