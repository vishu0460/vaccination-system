# VaxZone Environment Configuration
# Copy to .env and provide real values from your local secret store or deployment platform.

# Database
DB_NAME=vaccination_db
DB_URL=jdbc:mysql://localhost:3306/vaccination_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_ROOT_PASSWORD=replace-with-generated-root-password
DB_USERNAME=replace-with-generated-db-user
DB_PASSWORD=replace-with-generated-db-password

# JWT Security
JWT_SECRET=replace-with-generated-32-byte-or-longer-secret
JWT_ISSUER=vaccination-system

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=replace-with-smtp-username
MAIL_PASSWORD=replace-with-smtp-password
MAIL_FROM=noreply@yourdomain.com
APP_BASE_URL=https://yourdomain.com

# CORS (comma separated)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# SMS (Twilio - optional)
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Spring Profile
SPRING_PROFILES_ACTIVE=prod
APP_SEED_ENABLED=false
FRONTEND_URL=https://yourdomain.com

# Frontend
VITE_API_BASE_URL=https://your-api.example.com/api
VITE_APP_ENV=production
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
