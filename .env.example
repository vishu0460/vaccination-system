# VaxZone Environment Configuration
# Copy to .env and update values

# Database (MySQL Production)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vaccination_db
DB_USER=vaxzone_user
DB_PASSWORD=SecurePassword123!

# JWT Security (generate 32+ byte base64 secret)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-bytes-base64-encoded
JWT_ISSUER=vaxzone-production

# Email (SMTP)
MAIL_USERNAME=your-noreply@vaxzone.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@vaxzone.com
APP_BASE_URL=https://yourdomain.com

# CORS (comma separated)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# SMS (Twilio - optional)
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Admin (change immediately)
DEFAULT_ADMIN_EMAIL=vaxzone.vaccine@gmail.com
DEFAULT_ADMIN_PASSWORD=ChangeThisImmediately!

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

